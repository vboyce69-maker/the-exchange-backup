rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Listing photos: uploaded to listings/{userId}/{timestamp}.jpg by
    // the camera capture flow in src/app/create/page.tsx. Publicly
    // readable since buyers need to see listing photos without being
    // signed in to browse; write is restricted to the authenticated
    // owner's own folder, with basic type/size guards against abuse.
    match /listings/{userId}/{fileName} {
      allow read: if true;
      allow write: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.size < 10 * 1024 * 1024 &&
        request.resource.contentType.matches('image/.*');
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
