
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Core account data for buyers and sellers.",
      "properties": {
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastSignIn": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["buyer", "seller", "admin"] },
        "businessInfo": {
          "type": "object",
          "properties": {
            "registrationNumber": { "type": "string" },
            "vatNumber": { "type": "string" },
            "address": { "type": "string" }
          },
          "required": ["registrationNumber", "address"]
        }
      },
      "required": ["phoneNumber", "isVerified", "createdAt", "role"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Public-facing user profile with trust metrics.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "isIdVerified": { "type": "boolean" },
        "reliabilityScore": { "type": "number" },
        "transactionsCompleted": { "type": "number" },
        "disputeCount": { "type": "number" },
        "registrationDate": { "type": "string", "format": "date-time" },
        "bio": { "type": "string" },
        "profileImageUrl": { "type": "string" },
        "trustScore": { "type": "number" }
      },
      "required": ["id", "username", "isIdVerified", "reliabilityScore", "registrationDate"]
    },
    "ProductListing": {
      "title": "ProductListing",
      "type": "object",
      "description": "Item listed for sale or auction.",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string" },
        "isAuction": { "type": "boolean" },
        "highestBid": { "type": "number" },
        "isBulk": { "type": "boolean" },
        "quantity": { "type": "number" },
        "auctionEndDate": { "type": "string", "format": "date-time" },
        "isBoosted": { "type": "boolean", "description": "Whether the listing is currently prioritized." },
        "boostedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "sellerId", "title", "price", "status"]
    },
    "ListingFollow": {
      "title": "ListingFollow",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "listingId": { "type": "string" },
        "initialPrice": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    },
    "Notification": {
      "title": "Notification",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" },
        "listingId": { "type": "string" },
        "type": { "type": "string", "enum": ["price_drop", "system", "outbid"] }
      }
    },
    "ChatThread": {
      "title": "ChatThread",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "participants": { "type": "array", "items": { "type": "string" } },
        "lastMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "anonymous", "phone"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/users/{userId}",
        "definition": {
          "entityName": "User",
          "schema": { "$ref": "#/backend/entities/User" },
          "description": "Private account data."
        }
      },
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "Public profile and trust metrics."
        }
      },
      {
        "path": "/publicListings/{listingId}",
        "definition": {
          "entityName": "ProductListing",
          "schema": { "$ref": "#/backend/entities/ProductListing" },
          "description": "Marketplace listings."
        }
      },
      {
        "path": "/follows/{followId}",
        "definition": {
          "entityName": "ListingFollow",
          "schema": { "$ref": "#/backend/entities/ListingFollow" },
          "description": "Users following specific listings for price drops."
        }
      },
      {
        "path": "/notifications/{notificationId}",
        "definition": {
          "entityName": "Notification",
          "schema": { "$ref": "#/backend/entities/Notification" },
          "description": "User specific alerts and updates."
        }
      },
      {
        "path": "/chatThreads/{threadId}",
        "definition": {
          "entityName": "ChatThread",
          "schema": { "$ref": "#/backend/entities/ChatThread" },
          "description": "Messaging handshake metadata."
        }
      }
    ]
  }
}
