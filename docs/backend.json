{
  "entities": {
    "UserProfile": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a user within the LocalBid Exchange platform, storing their profile information, verification status, and aggregated performance metrics as a seller.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the UserProfile entity."
        },
        "username": {
          "type": "string",
          "description": "Unique username chosen by the user."
        },
        "email": {
          "type": "string",
          "description": "User's email address, used for communication and login.",
          "format": "email"
        },
        "firstName": {
          "type": "string",
          "description": "User's first name."
        },
        "lastName": {
          "type": "string",
          "description": "User's last name."
        },
        "bio": {
          "type": "string",
          "description": "A short biographical description provided by the user."
        },
        "profileImageUrl": {
          "type": "string",
          "description": "URL to the user's profile picture.",
          "format": "uri"
        },
        "locationLatitude": {
          "type": "number",
          "description": "The latitude coordinate of the user's primary location."
        },
        "locationLongitude": {
          "type": "number",
          "description": "The longitude coordinate of the user's primary location."
        },
        "isIdVerified": {
          "type": "boolean",
          "description": "Indicates if the user has completed the ID verification process."
        },
        "totalSalesCount": {
          "type": "number",
          "description": "The total number of successful sales made by this user."
        },
        "reliabilityScore": {
          "type": "number",
          "description": "An aggregate score reflecting the seller's reliability."
        },
        "registrationDate": {
          "type": "string",
          "description": "The date and time when the user registered.",
          "format": "date-time"
        }
      },
      "required": [
        "id",
        "username",
        "email",
        "firstName",
        "lastName",
        "locationLatitude",
        "locationLongitude",
        "isIdVerified",
        "totalSalesCount",
        "reliabilityScore",
        "registrationDate"
      ]
    },
    "Category": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Category",
      "type": "object",
      "description": "Defines a category for product listings.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the Category."
        },
        "name": {
          "type": "string",
          "description": "The name of the category."
        },
        "description": {
          "type": "string",
          "description": "A brief description of the category."
        }
      },
      "required": [
        "id",
        "name",
        "description"
      ]
    },
    "ProductListing": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ProductListing",
      "type": "object",
      "description": "Represents an item listed for sale or auction on the platform.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the ProductListing."
        },
        "sellerId": {
          "type": "string",
          "description": "Reference to the UserProfile of the seller."
        },
        "categoryId": {
          "type": "string",
          "description": "Reference to the Category."
        },
        "title": {
          "type": "string",
          "description": "The title of the product listing."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the product."
        },
        "condition": {
          "type": "string",
          "enum": ["New", "Like new", "Good", "Used"],
          "description": "The physical condition of the item."
        },
        "price": {
          "type": "number",
          "description": "The asking price."
        },
        "currency": {
          "type": "string",
          "description": "The currency code (e.g., 'ZAR')."
        },
        "imageUrls": {
          "type": "array",
          "description": "An array of URLs pointing to images of the product.",
          "items": {
            "type": "string"
          }
        },
        "listingLocationLatitude": {
          "type": "number",
          "description": "The latitude coordinate of the product's location."
        },
        "listingLocationLongitude": {
          "type": "number",
          "description": "The longitude coordinate of the product's location."
        },
        "postedDate": {
          "type": "string",
          "description": "The date and time when the product was listed.",
          "format": "date-time"
        },
        "status": {
          "type": "string",
          "description": "Current status (e.g., 'available', 'sold', 'auction_active')."
        },
        "isAuction": {
          "type": "boolean",
          "description": "Indicates if the listing is an auction."
        },
        "startingBid": {
          "type": "number",
          "description": "The initial bid amount for auctions."
        },
        "auctionEndDate": {
          "type": "string",
          "description": "The date and time when the auction ends.",
          "format": "date-time"
        },
        "viewCount": {
          "type": "number",
          "description": "The number of views."
        },
        "isBoosted": {
          "type": "boolean",
          "description": "Indicates if the listing is boosted."
        },
        "negotiable": {
          "type": "boolean",
          "description": "Indicates if the price is negotiable."
        }
      },
      "required": [
        "id",
        "sellerId",
        "categoryId",
        "title",
        "description",
        "condition",
        "price",
        "currency",
        "imageUrls",
        "listingLocationLatitude",
        "listingLocationLongitude",
        "postedDate",
        "status",
        "isAuction",
        "viewCount",
        "isBoosted",
        "negotiable"
      ]
    },
    "Transaction": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "buyerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "listingId": { "type": "string" },
        "finalAmount": { "type": "number" },
        "transactionDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["id", "buyerId", "sellerId", "listingId", "finalAmount", "transactionDate", "status"]
    },
    "Review": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Review",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "transactionId": { "type": "string" },
        "reviewerId": { "type": "string" },
        "sellerId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "reviewDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "transactionId", "reviewerId", "sellerId", "rating", "comment", "reviewDate"]
    },
    "Bid": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Bid",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "bidderId": { "type": "string" },
        "bidAmount": { "type": "number" },
        "bidDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "listingId", "bidderId", "bidAmount", "bidDate"]
    },
    "Conversation": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Conversation",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "user1Id": { "type": "string" },
        "user2Id": { "type": "string" },
        "createdDate": { "type": "string", "format": "date-time" },
        "lastMessageDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "user1Id", "user2Id", "createdDate", "lastMessageDate"]
    },
    "Message": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Message",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "senderId": { "type": "string" },
        "content": { "type": "string" },
        "sentDate": { "type": "string", "format": "date-time" },
        "isRead": { "type": "boolean" },
        "isFlaggedForScam": { "type": "boolean" }
      },
      "required": ["id", "conversationId", "senderId", "content", "sentDate", "isRead", "isFlaggedForScam"]
    },
    "MeetingPointSuggestion": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "MeetingPointSuggestion",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "conversationId": { "type": "string" },
        "suggestedByUserId": { "type": "string" },
        "latitude": { "type": "number" },
        "longitude": { "type": "number" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "status": { "type": "string" },
        "suggestionDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "conversationId", "suggestedByUserId", "latitude", "longitude", "name", "address", "status", "suggestionDate"]
    },
    "Report": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Report",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "reporterId": { "type": "string" },
        "reportedEntityId": { "type": "string" },
        "reportedEntityType": { "type": "string" },
        "reason": { "type": "string" },
        "details": { "type": "string" },
        "reportDate": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["id", "reporterId", "reportedEntityId", "reportedEntityType", "reason", "details", "reportDate", "status"]
    },
    "UserBlock": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "UserBlock",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "blockerId": { "type": "string" },
        "blockedId": { "type": "string" },
        "blockDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "blockerId", "blockedId", "blockDate"]
    },
    "ListingBoost": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ListingBoost",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "listingId": { "type": "string" },
        "boosterId": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "paymentTransactionRef": { "type": "string" },
        "boostType": { "type": "string" },
        "cost": { "type": "number" }
      },
      "required": ["id", "listingId", "boosterId", "startDate", "endDate", "paymentTransactionRef", "boostType", "cost"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "schema": { "$ref": "#/backend/entities/UserProfile" },
          "description": "User profile information."
        }
      },
      {
        "path": "/categories/{categoryId}",
        "definition": {
          "entityName": "Category",
          "schema": { "$ref": "#/backend/entities/Category" },
          "description": "Global product categories."
        }
      },
      {
        "path": "/publicListings/{listingId}",
        "definition": {
          "entityName": "ProductListing",
          "schema": { "$ref": "#/backend/entities/ProductListing" },
          "description": "Active product listings."
        }
      },
      {
        "path": "/userProfiles/{userId}/draftListings/{listingId}",
        "definition": {
          "entityName": "ProductListing",
          "schema": { "$ref": "#/backend/entities/ProductListing" },
          "description": "Private draft listings."
        }
      },
      {
        "path": "/publicListings/{listingId}/bids/{bidId}",
        "definition": {
          "entityName": "Bid",
          "schema": { "$ref": "#/backend/entities/Bid" },
          "description": "Auction bids."
        }
      },
      {
        "path": "/conversations/{conversationId}",
        "definition": {
          "entityName": "Conversation",
          "schema": { "$ref": "#/backend/entities/Conversation" },
          "description": "Messaging threads."
        }
      },
      {
        "path": "/conversations/{conversationId}/messages/{messageId}",
        "definition": {
          "entityName": "Message",
          "schema": { "$ref": "#/backend/entities/Message" },
          "description": "Chat messages."
        }
      },
      {
        "path": "/conversations/{conversationId}/meetingPointSuggestions/{suggestionId}",
        "definition": {
          "entityName": "MeetingPointSuggestion",
          "schema": { "$ref": "#/backend/entities/MeetingPointSuggestion" },
          "description": "Suggested meeting points."
        }
      },
      {
        "path": "/transactions/{transactionId}",
        "definition": {
          "entityName": "Transaction",
          "schema": { "$ref": "#/backend/entities/Transaction" },
          "description": "Purchase records."
        }
      },
      {
        "path": "/userProfiles/{sellerId}/reviews/{reviewId}",
        "definition": {
          "entityName": "Review",
          "schema": { "$ref": "#/backend/entities/Review" },
          "description": "Buyer reviews."
        }
      },
      {
        "path": "/reports/{reportId}",
        "definition": {
          "entityName": "Report",
          "schema": { "$ref": "#/backend/entities/Report" },
          "description": "User-submitted reports."
        }
      },
      {
        "path": "/userProfiles/{blockerId}/blockedUsers/{blockedId}",
        "definition": {
          "entityName": "UserBlock",
          "schema": { "$ref": "#/backend/entities/UserBlock" },
          "description": "Blocked users."
        }
      },
      {
        "path": "/userProfiles/{boosterId}/listingBoosts/{boostId}",
        "definition": {
          "entityName": "ListingBoost",
          "schema": { "$ref": "#/backend/entities/ListingBoost" },
          "description": "Listing promotion records."
        }
      }
    ]
  }
}
