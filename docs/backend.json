{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Core account data for buyers and sellers.",
      "properties": {
        "phoneNumber": { "type": "string" },
        "displayName": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "role": { "type": "string", "enum": ["buyer", "seller", "admin"] }
      },
      "required": ["phoneNumber", "isVerified", "role"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Public-facing user profile with trust metrics.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "kycStatus": { "type": "string", "enum": ["unverified", "pending", "verified"] },
        "reliabilityScore": { "type": "number" },
        "transactionsCompleted": { "type": "number" }
      },
      "required": ["id", "kycStatus", "reliabilityScore"]
    },
    "ProductListing": {
      "title": "ProductListing",
      "type": "object",
      "description": "Item listed for sale or auction.",
      "properties": {
        "id": { "type": "string" },
        "sellerId": { "type": "string" },
        "title": { "type": "string" },
        "price": { "type": "number" },
        "status": { "type": "string" }
      },
      "required": ["id", "sellerId", "title", "price", "status"]
    },
    "EscrowHold": {
      "title": "EscrowHold",
      "type": "object",
      "properties": {
        "transactionId": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string", "enum": ["held", "released", "disputed", "refunded"] },
        "heldAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "phone", "google"]
  },
  "firestore": {
    "structure": [
      {
        "path": "/userProfiles/{userId}",
        "definition": {
          "entityName": "UserProfile",
          "description": "User profiles and trust metrics."
        }
      },
      {
        "path": "/publicListings/{listingId}",
        "definition": {
          "entityName": "ProductListing",
          "description": "Marketplace listings."
        }
      },
      {
        "path": "/transactions/{txId}",
        "definition": {
          "description": "Marketplace trade records."
        }
      },
      {
        "path": "/escrowHolds/{holdId}",
        "definition": {
          "entityName": "EscrowHold",
          "description": "Platform fund protection records."
        }
      },
      {
        "path": "/auditLogs/{logId}",
        "definition": {
          "description": "Security and administrative audit trail."
        }
      },
      {
        "path": "/fraudEvents/{eventId}",
        "definition": {
          "description": "Detected suspicious activities."
        }
      }
    ]
  }
}
