rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Public read for user profiles to support the "Founding 1000" counter and trust badges
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Public read for listings so visitors can browse
    match /publicListings/{listingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Default: Authenticated users can read/write everything else (chats, etc)
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}