
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Standard Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Listings - anyone can read, authenticated users can write (create/bid)
    match /publicListings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.sellerId) || 
        (
          // Bidding Logic: Allow if changing ONLY bid fields and amount is higher
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['highestBid', 'highestBidderId', 'status']) &&
          request.resource.data.highestBid > (resource.data.highestBid || resource.data.price || 0) &&
          request.resource.data.highestBidderId == request.auth.uid
        )
      );
      allow delete: if isOwner(resource.data.sellerId);
    }

    // Users/Profiles - anyone can read, owner can write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated();
      }
    }

    // Settings - owner only
    match /settings/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Referrals - authenticated users only
    match /referrals/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Messaging - Participants only
    match /chatThreads/{threadId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participants;
        allow create: if isAuthenticated();
      }
    }

    // Disputes - Reporter or Admin only
    match /disputes/{disputeId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.reporterId || request.auth.token.role == 'admin');
    }

    // Moderation - Admin only
    match /moderationQueue/{recordId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && request.auth.token.role == 'admin';
    }
  }
}
