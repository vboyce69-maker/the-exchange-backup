
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Standard Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Listings - authenticated users can read all, owners can write
    match /publicListings/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.sellerId) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['highestBid', 'highestBidderId']) && 
         request.resource.data.highestBid > resource.data.highestBid)
      );
      allow delete: if isOwner(resource.data.sellerId);
    }

    // Users/Profiles - Strictly owner only for writing, authenticated read
    match /userProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);
    }

    // Referrals - track invites securely
    match /referrals/{referralId} {
      allow read: if isOwner(referralId);
      allow write: if isAuthenticated();
    }

    // Notifications - strictly owner only
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated();
    }

    // Messaging - Participants only
    match /chatThreads/{threadId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participants;
        allow create: if isAuthenticated();
      }
    }

    // Disputes - reporting user or admin
    match /disputes/{disputeId} {
      allow read: if isAuthenticated() && (resource.data.reporterId == request.auth.uid || request.auth.token.admin == true);
      allow create: if isAuthenticated();
    }
  }
}
