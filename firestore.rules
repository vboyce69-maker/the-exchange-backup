/**
 * LocalBid Exchange - Firestore Security Rules
 *
 * Core Philosophy:
 * This ruleset implements a robust, owner-centric security model designed for a local marketplace.
 * It leverages "Authorization Independence" by ensuring that every document contains the 
 * necessary metadata (e.g., sellerId, buyerId, participantIds) to make access decisions 
 * without performing expensive cross-document lookups (get() calls).
 *
 * Data Structure:
 * - Public Discovery: Top-level collections like /products, /auctions, and /users (profiles) 
 *   are publicly readable to facilitate search and discovery.
 * - Private Transactions: /transactions and /conversations are restricted to the 
 *   specific participants (buyer/seller or sender/receiver).
 * - User-Owned Branches: Collections like /blockedUsers are nested under the user's 
 *   ID to enforce strict path-based ownership.
 *
 * Key Security Decisions:
 * - Denormalization: Seller IDs and Participant IDs are mirrored within documents to 
 *   ensure high-performance, single-read authorization.
 * - Prototyping Flexibility: While authorization is strictly enforced based on identity, 
 *   the specific schema (data types and shapes) is not strictly validated to allow 
 *   for rapid iterative development of marketplace features.
 * - Relational Integrity: On creation, documents must correctly link themselves to 
 *   the authenticated user's ID to prevent identity spoofing.
 */

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---

    /** Checks if the user is authenticated. */
    function isSignedIn() {
      return request.auth != null;
    }

    /** Checks if the authenticated user's UID matches the provided userId. */
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    /** Checks if the document belongs to the user via a field (e.g., sellerId, buyerId). */
    function isFieldOwner(fieldName) {
      return isSignedIn() && resource.data[fieldName] == request.auth.uid;
    }

    /** Validates that the incoming document data sets the owner field to the current user. */
    function isIncomingFieldOwner(fieldName) {
      return isSignedIn() && request.resource.data[fieldName] == request.auth.uid;
    }

    /** Combined check for update/delete to ensure existence and ownership. */
    function isExistingFieldOwner(fieldName) {
      return resource != null && isFieldOwner(fieldName);
    }
    
    /** Checks if user is an admin via a dedicated roles collection. */
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    /**
     * @description Public profile information. Users can manage their own data.
     * @path /users/{userId}
     * @allow (get, list) if true; (create) if auth matches path; (update) if auth matches path and ID is immutable.
     * @deny (write) if unauthorized or trying to modify someone else's profile.
     * @principle Path-based ownership for writes with public read access.
     */
    match /users/{userId} {
      allow get, list: if true;
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingFieldOwner('id') && userId == request.auth.uid && request.resource.data.id == resource.data.id;
      allow delete: if false; // Profiles are typically not deleted by users in this app.
    }

    /**
     * @description Marketplace products. Publicly viewable, editable only by the seller.
     * @path /products/{productId}
     * @allow (get, list) if true; (create) if sellerId is sender; (update, delete) if user is seller.
     * @deny (write) if sellerId mismatch.
     * @principle Field-based ownership for decentralized authorization.
     */
    match /products/{productId} {
      allow get, list: if true;
      allow create: if isIncomingFieldOwner('sellerId');
      allow update, delete: if isExistingFieldOwner('sellerId') && request.resource.data.sellerId == resource.data.sellerId;
    }

    /**
     * @description Auction metadata. Publicly viewable, managed by the product seller.
     * @path /auctions/{auctionId}
     * @allow (get, list) if true; (create) if denormalized sellerId matches; (update) if user is seller.
     * @deny (write) if sellerId mismatch.
     * @principle Denormalization of sellerId enables owner-validation on auctions.
     */
    match /auctions/{auctionId} {
      allow get, list: if true;
      allow create: if isIncomingFieldOwner('sellerId');
      allow update, delete: if isExistingFieldOwner('sellerId') && request.resource.data.sellerId == resource.data.sellerId;

      /**
       * @description Bids on an auction. Readable by bidder and seller.
       * @path /auctions/{auctionId}/bids/{bidId}
       * @allow (get, list) if user is bidder or seller; (create) if user is bidder.
       * @deny (read) if user is a third party.
       * @principle Restricts financial bidding data to relevant parties.
       */
      match /bids/{bidId} {
        allow get, list: if isFieldOwner('bidderId') || isFieldOwner('sellerId');
        allow create: if isIncomingFieldOwner('bidderId');
        allow update, delete: if false; // Bids are immutable for integrity.
      }
    }

    /**
     * @description Private transaction records between a buyer and a seller.
     * @path /transactions/{transactionId}
     * @allow (get, list, update) if user is buyerId or sellerId.
     * @deny (get, list) if user is not a participant.
     * @principle Multi-party access control via denormalized relationship fields.
     */
    match /transactions/{transactionId} {
      allow get, list: if isFieldOwner('buyerId') || isFieldOwner('sellerId');
      allow create: if isIncomingFieldOwner('buyerId') || isIncomingFieldOwner('sellerId');
      allow update: if (isExistingFieldOwner('buyerId') || isExistingFieldOwner('sellerId')) && request.resource.data.buyerId == resource.data.buyerId && request.resource.data.sellerId == resource.data.sellerId;
      allow delete: if false; // Transactions must be preserved for audit.
    }

    /**
     * @description Seller reviews. Publicly readable, managed by the reviewer.
     * @path /users/{sellerId}/reviews/{reviewId}
     * @allow (get, list) if true; (create) if reviewerId is current user.
     * @deny (update) if reviewerId mismatch.
     * @principle Public reputation system with reviewer-only write access.
     */
    match /users/{sellerId}/reviews/{reviewId} {
      allow get, list: if true;
      allow create: if isIncomingFieldOwner('reviewerId');
      allow update, delete: if isExistingFieldOwner('reviewerId');
    }

    /**
     * @description Conversation threads. Restricted to participants.
     * @path /conversations/{conversationId}
     * @allow (get, list) if user UID is in participantIds array.
     * @deny (get) if user not in participantIds.
     * @principle Array-based membership for shared access.
     */
    match /conversations/{conversationId} {
      allow get, list: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow create: if isSignedIn() && request.auth.uid in request.resource.data.participantIds;
      allow update: if isSignedIn() && request.auth.uid in resource.data.participantIds;
      allow delete: if false;

      /**
       * @description Messages within a conversation. Restricted to sender and receiver.
       * @path /conversations/{conversationId}/messages/{messageId}
       * @allow (get, list) if user is sender or receiver. (create) if user is sender.
       * @deny (list) if user is not in the message participants.
       * @principle Granular message security based on denormalized sender/receiver IDs.
       */
      match /messages/{messageId} {
        allow get, list: if isFieldOwner('senderId') || isFieldOwner('receiverId');
        allow create: if isIncomingFieldOwner('senderId');
        allow update: if isExistingFieldOwner('receiverId'); // To allow 'isRead' updates by receiver.
        allow delete: if false;
      }
    }

    /**
     * @description Abuse reports. Readable by reporter or admins.
     * @path /reports/{reportId}
     * @allow (create, get) if user is reporter; (list) if admin.
     * @deny (get) if trying to read someone else's report.
     * @principle User-submitted data with administrative oversight.
     */
    match /reports/{reportId} {
      allow get: if isFieldOwner('reporterId') || isAdmin();
      allow list: if isAdmin();
      allow create: if isIncomingFieldOwner('reporterId');
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    /**
     * @description Personal block lists. Only accessible by the blocking user.
     * @path /users/{blockerId}/blockedUsers/{blockedId}
     * @allow (all) if auth matches blockerId.
     * @deny (all) if auth does not match blockerId.
     * @principle Path-based isolation for private user settings.
     */
    match /users/{blockerId}/blockedUsers/{blockedId} {
      allow get, list, create, update, delete: if isOwner(blockerId);
    }

    /**
     * @description Paid boosts for product visibility. Managed by the seller.
     * @path /products/{productId}/listingBoosts/{boostId}
     * @allow (get, list) if true; (create, update) if user is boosterId.
     * @deny (write) if boosterId mismatch.
     * @principle Ownership validation on commercial features.
     */
    match /products/{productId}/listingBoosts/{boostId} {
      allow get, list: if true;
      allow create: if isIncomingFieldOwner('boosterId');
      allow update: if isExistingFieldOwner('boosterId');
      allow delete: if isAdmin();
    }
  }
}