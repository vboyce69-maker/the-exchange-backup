rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Assumed Data Models & Integrity Helpers
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Validation: String size protection to prevent DoS (Phase 7)
    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators (Phase 3)
    // ===============================================================

    function isValidListing(data) {
      return data.keys().hasAll(['sellerId', 'title', 'price', 'status']) &&
             data.sellerId == request.auth.uid &&
             data.price is number && data.price >= 0 &&
             isValidString(data.title, 100) &&
             data.status in ['available', 'pending_meetup', 'sold', 'pending_review'];
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['id', 'kycStatus', 'reliabilityScore']) &&
             data.id == request.auth.uid &&
             data.reliabilityScore is number &&
             data.kycStatus in ['unverified', 'pending', 'verified'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /publicListings/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isValidListing(request.resource.data);
      allow update: if isAuthenticated() && (
        (isOwner(resource.data.sellerId) && isValidListing(request.resource.data)) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['highestBid', 'highestBidderId']) && 
         request.resource.data.highestBid > resource.data.highestBid)
      );
      allow delete: if isOwner(resource.data.sellerId) || isAdmin();
    }

    match /userProfiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidProfile(request.resource.data);
      allow update: if isOwner(userId) && isValidProfile(request.resource.data) && 
                      request.resource.data.reliabilityScore == resource.data.reliabilityScore; // Prevent self-trust escalation
      
      match /reviews/{reviewId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated() && request.resource.data.reviewerId == request.auth.uid;
      }
    }

    match /transactions/{txId} {
      allow read: if isAuthenticated() && (resource.data.buyerId == request.auth.uid || resource.data.sellerId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.buyerId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /escrowHolds/{holdId} {
      allow read: if isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /chatThreads/{threadId} {
      allow read, update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participants;
        allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      }
    }

    match /notifications/{notificationId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /systemErrors/{errorId} {
      allow read: if isAdmin();
      allow create: if true;
    }
    
    match /fraudEvents/{eventId} {
      allow read, write: if isAdmin();
    }
  }
}
