rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Enterprise Security Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Scam Blocking Rules ---
    // Reject messages that are flagged as high risk by the client-side/AI engine
    function isSafeMessage(data) {
      return data.riskScore == null || data.riskScore < 80;
    }

    match /publicListings/{listingId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.price > 0;
      allow update: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    match /userProfiles/{userId} {
      allow read: if isSignedIn();
      allow create, update: if isOwner(userId);
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && request.auth.uid != userId;
      }
    }

    match /conversations/{conversationId} {
      allow read: if isSignedIn();
      
      match /messages/{messageId} {
        // Enforce safe message writes and authentication
        allow create: if isSignedIn() && isSafeMessage(request.resource.data);
        allow read: if isSignedIn();
      }
    }

    match /securityLogs/{logId} {
      // Users can only write their own security events
      allow create: if isSignedIn();
      allow read: if isAdmin();
    }

    match /moderationQueue/{recordId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
