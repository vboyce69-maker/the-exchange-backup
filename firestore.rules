
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    function isExistingOwner(userId) {
      return resource != null && isOwner(userId);
    }

    // --- Rules ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if false; 
    }

    match /userProfiles/{userId} {
      allow get, list: if isSignedIn();
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      allow update: if isExistingOwner(userId) && request.resource.data.id == resource.data.id;
      allow delete: if isExistingOwner(userId) || isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin();
    }

    match /publicListings/{listingId} {
      // Allow everyone (authenticated or not) to read and list public listings
      allow read, list: if true;
      
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.sellerId) && request.resource.data.sellerId == resource.data.sellerId;
      allow delete: if isExistingOwner(resource.data.sellerId) || isAdmin();

      match /bids/{bidId} {
        allow get, list: if isSignedIn() && (isOwner(resource.data.bidderId) || isOwner(resource.data.listingSellerId));
        allow create: if isSignedIn() && request.resource.data.bidderId == request.auth.uid;
        allow update: if isExistingOwner(resource.data.bidderId) && request.resource.data.bidderId == resource.data.bidderId;
        allow delete: if isExistingOwner(resource.data.bidderId) || isAdmin();
      }
    }

    match /userProfiles/{userId}/draftListings/{listingId} {
      allow read, write: if isOwner(userId);
    }

    match /userProfiles/{userId}/blockedUsers/{blockedId} {
      allow read, write: if isOwner(userId);
    }

    match /userProfiles/{userId}/listingBoosts/{boostId} {
      allow read, write: if isOwner(userId);
    }

    match /userProfiles/{sellerId}/reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.reviewerId) && request.resource.data.reviewerId == resource.data.reviewerId;
      allow delete: if isExistingOwner(resource.data.reviewerId) || isAdmin();
    }

    match /conversations/{conversationId} {
      allow read: if isSignedIn() && (isOwner(resource.data.user1Id) || isOwner(resource.data.user2Id));
      allow create: if isSignedIn() && (request.resource.data.user1Id == request.auth.uid || request.resource.data.user2Id == request.auth.uid);
      allow update: if isSignedIn() && (isOwner(resource.data.user1Id) || isOwner(resource.data.user2Id));
      allow delete: if isAdmin();

      match /messages/{messageId} {
        allow read: if isSignedIn() && request.auth.uid in resource.data.conversationParticipants.keys();
        allow create: if isSignedIn() && request.auth.uid in request.resource.data.conversationParticipants.keys();
        allow update, delete: if false;
      }

      match /meetingPointSuggestions/{suggestionId} {
        allow read: if isSignedIn() && request.auth.uid in resource.data.conversationParticipants.keys();
        allow create: if isSignedIn() && request.auth.uid in request.resource.data.conversationParticipants.keys();
        allow update: if isSignedIn() && request.auth.uid in resource.data.conversationParticipants.keys();
        allow delete: if isAdmin();
      }
    }

    match /transactions/{transactionId} {
      allow get, list: if isSignedIn() && (isOwner(resource.data.buyerId) || isOwner(resource.data.sellerId));
      allow create, update: if isSignedIn() && (request.resource.data.buyerId == request.auth.uid || request.resource.data.sellerId == request.auth.uid);
      allow delete: if isAdmin();
    }

    match /reports/{reportId} {
      allow get: if isExistingOwner(resource.data.reporterId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && request.resource.data.reporterId == request.auth.uid;
      allow update: if isExistingOwner(resource.data.reporterId) && request.resource.data.reporterId == resource.data.reporterId;
      allow delete: if isAdmin();
    }
  }
}
