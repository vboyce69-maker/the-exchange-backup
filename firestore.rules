
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Rules ---

    // Marketplace Transparency: Public listings are readable by anyone
    match /publicListings/{listingId} {
      allow read, list: if true;
      
      // Mutations require authentication and ownership
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      allow update: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
      allow delete: if isSignedIn() && (resource.data.sellerId == request.auth.uid || isAdmin());
    }

    match /userProfiles/{userId} {
      // Profiles are visible to signed-in users
      allow read: if isSignedIn();
      allow list: if isSignedIn();
      
      // Only the owner can manage their own profile
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) 
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.reliabilityScore == resource.data.reliabilityScore
                    && request.resource.data.isIdVerified == resource.data.isIdVerified;
      
      allow delete: if isAdmin();

      // Reviews within a profile
      match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
        allow update, delete: if isAdmin();
      }
    }

    match /conversations/{conversationId} {
      // Privacy: Only participants can read or interact with the conversation
      allow read, write: if isSignedIn() && (request.auth.uid == resource.data.user1Id || request.auth.uid == resource.data.user2Id);

      match /messages/{messageId} {
        allow read, create: if isSignedIn();
      }
    }

    match /roles_admin/{userId} {
      allow read: if isSignedIn();
      allow write: if false; 
    }
  }
}
