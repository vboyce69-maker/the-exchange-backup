
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // PII Protection: Sensitive fields should only be readable by the owner or admin
    function isNotSensitive() {
      let sensitiveFields = ['email', 'phone', 'idNumber', 'locationLatitude', 'locationLongitude'];
      return !request.resource.data.keys().hasAny(sensitiveFields);
    }

    // --- Rules ---

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow write: if false; 
    }

    match /userProfiles/{userId} {
      // Public profile data is readable by all signed-in users
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      // Only owner can create/update their own profile
      allow create: if isOwner(userId) && request.resource.data.id == userId;
      
      // Prevent users from modifying their own reliability scores or verification status directly
      allow update: if isOwner(userId) 
                    && request.resource.data.id == resource.data.id
                    && request.resource.data.reliabilityScore == resource.data.reliabilityScore
                    && request.resource.data.isIdVerified == resource.data.isIdVerified;
      
      allow delete: if isAdmin();

      // Nested Reviews: Publicly readable, but only buyers can create
      match /reviews/{reviewId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && request.resource.data.buyerId == request.auth.uid;
        allow update, delete: if isAdmin();
      }
    }

    match /publicListings/{listingId} {
      // Marketplace Transparency: All listings are readable/listable by anyone
      allow read, list: if true;
      
      // Integrity: Seller ID must match authenticated user
      allow create: if isSignedIn() && request.resource.data.sellerId == request.auth.uid;
      
      // Security: Only owner or admin can modify/delete
      allow update: if (isSignedIn() && resource.data.sellerId == request.auth.uid) || isAdmin();
      allow delete: if (isSignedIn() && resource.data.sellerId == request.auth.uid) || isAdmin();
    }

    match /conversations/{conversationId} {
      // Privacy: Only participants can read or interact with the conversation
      allow read, write: if isSignedIn() && (request.auth.uid == resource.data.user1Id || request.auth.uid == resource.data.user2Id || request.auth.uid == request.resource.data.user1Id || request.auth.uid == request.resource.data.user2Id);

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn();
      }
    }

    // Global protection for all other paths
    match /{path=**} {
      allow read, write: if isAdmin();
    }
  }
}
