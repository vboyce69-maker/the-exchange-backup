
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Standard Helpers
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Listings - anyone can read, authenticated users can write
    match /publicListings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated(); // Simplified for MVP updates like price drops
      allow delete: if isOwner(resource.data.sellerId);
    }

    // Users/Profiles - anyone can read, owner can write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Follows - owner only for creation/deletion
    match /follows/{followId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.userId || request.auth.uid == get(/databases/$(database)/documents/publicListings/$(resource.data.listingId)).data.sellerId);
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow list: if isAuthenticated();
    }

    // Notifications - strictly owner only
    match /notifications/{notificationId} {
      allow read, update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated(); // System allows creation for others (e.g. price drops)
    }

    // Messaging - Participants only
    match /chatThreads/{threadId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participants;
        allow create: if isAuthenticated();
      }
    }
  }
}
