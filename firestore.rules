
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Security Infrastructure & Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    // Validation: String size protection to prevent DoS
    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidListing(data) {
      return data.keys().hasAll(['sellerId', 'title', 'price', 'status']) &&
             data.sellerId == request.auth.uid &&
             data.price is number && data.price >= 0 &&
             isValidString(data.title, 100) &&
             data.status in ['available', 'pending_meetup', 'sold', 'pending_review'];
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['id', 'kycStatus', 'reliabilityScore']) &&
             data.id == request.auth.uid &&
             data.reliabilityScore is number &&
             data.kycStatus in ['unverified', 'pending', 'verified'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /publicListings/{listingId} {
      allow read: if true; // Marketplace is public
      allow create: if isAuthenticated() && isValidListing(request.resource.data);
      allow update: if isAuthenticated() && (
        (isOwner(resource.data.sellerId) && isValidListing(request.resource.data)) || 
        // Bidding Protocol: Allow non-owners to update ONLY bid fields
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['highestBid', 'highestBidderId', 'isBoosted', 'boostedAt']) && 
         (request.resource.data.highestBid > resource.data.highestBid || isOwner(resource.data.sellerId)))
      );
      allow delete: if isOwner(resource.data.sellerId) || isAdmin();
    }

    match /userProfiles/{userId} {
      allow read: if isAuthenticated(); // Public profiles for trust
      allow create: if isOwner(userId) && isValidProfile(request.resource.data);
      allow update: if isOwner(userId) || isAdmin();
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() && request.resource.data.reviewerId == request.auth.uid;
      }
    }

    match /notifications/{id} {
      allow list: if isAuthenticated() && request.query.limit <= 50;
      allow get, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAdmin() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
    }

    match /follows/{id} {
      allow list: if isAuthenticated();
      allow get, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /chatThreads/{threadId} {
      allow read, update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participants;
        allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      }
    }

    match /disputes/{disputeId} {
      allow read: if isAuthenticated() && (resource.data.reporterId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() && request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /moderationQueue/{id} {
      allow read, write: if isAdmin();
    }

    match /referrals/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if isAuthenticated();
    }

    match /systemErrors/{errorId} {
      allow read: if isAdmin();
      allow create: if true;
    }
  }
}
