rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: userProfiles/{userId}
    // Fields: id, kycStatus, reliabilityScore, trustScore, etc.
    //
    // Collection: publicListings/{listingId}
    // Fields: sellerId, title, price, status, highestBid, etc.
    //
    // Collection: notifications/{id}
    // Fields: userId, title, message, isRead, timestamp
    //
    // Collection: referrals/{userId}
    // Fields: referralCode, invites, credits, createdAt
    //
    // ===============================================================

    // ===============================================================
    // Security Infrastructure & Helper Functions
    // ===============================================================

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isValidString(val, maxLen) {
      return val is string && val.size() <= maxLen;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidListing(data) {
      return data.keys().hasAll(['sellerId', 'title', 'price', 'status']) &&
             data.sellerId == request.auth.uid &&
             data.price is number && data.price >= 0 &&
             isValidString(data.title, 100) &&
             data.status in ['available', 'pending_meetup', 'sold', 'pending_review', 'auction_active'];
    }

    function isValidProfile(data) {
      return data.keys().hasAll(['id', 'kycStatus', 'reliabilityScore']) &&
             data.id == request.auth.uid &&
             data.reliabilityScore is number &&
             data.kycStatus in ['unverified', 'pending', 'verified'];
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    match /publicListings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated() && isValidListing(request.resource.data);
      allow update: if isAuthenticated() && (
        (isOwner(resource.data.sellerId) && isValidListing(request.resource.data)) ||
        // Bidding: non-owners can only update bid fields
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['highestBid', 'highestBidderId']) &&
         request.resource.data.highestBid > resource.data.highestBid)
      );
      allow delete: if isOwner(resource.data.sellerId) || isAdmin();
    }
// Transactions are created and updated exclusively by Cloud Functions
    // (createTransaction, paystackWebhook, confirmReceiptAndRelease) using
    // the Admin SDK, which is not subject to these rules. Clients only
    // ever need to read a transaction to show payment/escrow status, so
    // client writes are denied entirely.
    match /transactions/{transactionId} {
      allow read: if isAuthenticated() &&
        (isOwner(resource.data.buyerId) || isOwner(resource.data.sellerId));
      allow write: if false;
    }

    match /userProfiles/{userId} {
      allow read: if isAuthenticated();
      allow create: if isOwner(userId) && isValidProfile(request.resource.data);
      allow update: if (isOwner(userId) &&
        !request.resource.data.diff(resource.data)
          .affectedKeys().hasAny(['kycStatus', 'reliabilityScore', 'trustScore']))
        || isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated() &&
          request.resource.data.reviewerId == request.auth.uid;
      }
    }

    match /notifications/{id} {
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow create: if isAdmin() || (isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        (request.resource.data.type == 'outbid' &&
         exists(/databases/$(database)/documents/publicListings/$(request.resource.data.listingId)) &&
         get(/databases/$(database)/documents/publicListings/$(request.resource.data.listingId)).data.highestBidderId == request.auth.uid)
      ));
    }

    match /follows/{id} {
      allow list: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow get, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
    }

    match /chatThreads/{threadId} {
      allow read, update: if isAuthenticated() &&
        request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated() &&
        request.auth.uid in request.resource.data.participants;

      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
          exists(/databases/$(database)/documents/chatThreads/$(threadId)) &&
          request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participants;
        allow create: if isAuthenticated() &&
          request.resource.data.senderId == request.auth.uid &&
          exists(/databases/$(database)/documents/chatThreads/$(threadId)) &&
          request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participants;
      }
    }

    match /disputes/{disputeId} {
      allow read: if isAuthenticated() &&
        (resource.data.reporterId == request.auth.uid || isAdmin());
      allow create: if isAuthenticated() &&
        request.resource.data.reporterId == request.auth.uid;
      allow update, delete: if isAdmin();
    }

    match /moderationQueue/{id} {
      allow read, write: if isAdmin();
    }

    match /referrals/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
    }

    match /auditLogs/{logId} {
      allow read: if isAdmin();
      allow create: if false; // Cloud Functions only
    }

    match /systemErrors/{errorId} {
      allow read: if isAdmin();
      allow create: if false; // Cloud Functions only
    }

    match /escrow/{escrowId} {
      allow read: if isAuthenticated() && (
        resource.data.buyerId == request.auth.uid ||
        resource.data.sellerId == request.auth.uid ||
        isAdmin()
      );
      allow create, update, delete: if false; // Cloud Functions only
    }

  } // end match /databases
} // end service