
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Profiles: Public read, owner write
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
      
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isAuthenticated();
      }
    }

    // Listings: Public read, owner modify
    match /publicListings/{listingId} {
      allow read: if true;
      allow create: if isAuthenticated();
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.sellerId || request.auth.uid == resource.data.highestBidderId);
    }

    // Messaging: Participants only
    match /chatThreads/{threadId} {
      allow read, write: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      
      match /messages/{messageId} {
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participants;
        allow create: if isAuthenticated();
      }
    }

    // Disputes: Reporters can create, participants can read
    match /disputes/{disputeId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.reporterId || request.auth.token.role == 'admin');
    }

    // Referrals: Owner only
    match /referrals/{userId} {
      allow read, write: if isOwner(userId);
    }

    // Moderation: Admin only
    match /moderationQueue/{recordId} {
      allow create: if isAuthenticated();
      allow read: if isAuthenticated() && request.auth.token.role == 'admin';
    }
  }
}
