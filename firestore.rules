
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // ===============================================================
    // Collection Rules
    // ===============================================================

    // Marketplace Listings
    match /publicListings/{listingId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && (
        isOwner(resource.data.sellerId) || 
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['highestBid', 'highestBidderId']) && 
         request.resource.data.highestBid > resource.data.highestBid)
      );
      allow delete: if isOwner(resource.data.sellerId);
    }

    // Public Profiles & Trust Metrics
    match /userProfiles/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);

      // Verified Feedback Subcollection
      match /reviews/{reviewId} {
        allow read: if isAuthenticated();
        allow create: if isAuthenticated();
      }
    }

    // Price Watch / Listing Follows
    match /follows/{followId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Market Alerts & Notifications
    match /notifications/{notificationId} {
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isAuthenticated() && (
        // For queries, Firestore checks that the filter matches this condition
        resource.data.userId == request.auth.uid
      );
    }

    // Secure Peer-to-Peer Messaging
    match /chatThreads/{threadId} {
      allow read: if isAuthenticated() && request.auth.uid in resource.data.participants;
      allow create: if isAuthenticated();
      allow update: if isAuthenticated() && request.auth.uid in resource.data.participants;
      
      match /messages/{messageId} {
        // Only participants can read messages
        allow read: if isAuthenticated() && request.auth.uid in get(/databases/$(database)/documents/chatThreads/$(threadId)).data.participants;
        allow create: if isAuthenticated();
      }
    }

    // Incident Reporting & Disputes
    match /disputes/{disputeId} {
      allow read: if isAuthenticated() && (resource.data.reporterId == request.auth.uid || request.auth.token.admin == true);
      allow create: if isAuthenticated();
    }

    // Referral System Logs
    match /referrals/{referralId} {
      allow read: if isOwner(referralId);
      allow write: if isAuthenticated();
    }

    // System Stability Logs (Admin Only)
    match /systemErrors/{errorId} {
      allow read: if isAuthenticated() && request.auth.token.admin == true;
      allow create: if true; // Allow anonymous error logging
      allow update: if isAuthenticated() && request.auth.token.admin == true;
    }
    
    // Moderation Queue (Admin Only)
    match /moderationQueue/{recordId} {
      allow read, write: if isAuthenticated() && request.auth.token.admin == true;
    }
  }
}
