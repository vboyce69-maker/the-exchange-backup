rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Core user account security: Only the owner can access their private account data
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User Profiles: Publicly readable for trust/verification, but only editable by the owner
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Public Listings: Anyone can browse items, but only the verified seller can modify them
    match /publicListings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.sellerId;
    }

    // Moderation Queue: Users can submit reports, but data is restricted to system administrators
    match /moderationQueue/{recordId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false; 
    }

    // System Errors: Allow anonymous reporting of crashes for AI analysis and system recovery
    match /systemErrors/{errorId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}