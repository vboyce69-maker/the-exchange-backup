rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Ownership-based rules for user accounts
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // User Profiles: Publicly readable for trust/verification, but only editable by owner
    match /userProfiles/{userId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Public Listings: Anyone can view, but only the seller can edit or delete
    match /publicListings/{listingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.sellerId;
    }

    // Moderation Queue: Users can report content, but only system admins can read/manage
    match /moderationQueue/{recordId} {
      allow create: if request.auth != null;
      allow read, update, delete: if false; 
    }

    // System Errors: Allow anonymous reporting of crashes for AI analysis
    match /systemErrors/{errorId} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}